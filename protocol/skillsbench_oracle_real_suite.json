{
  "schema_version": "0.1.0",
  "suite_name": "skillsbench-oracle-real-suite",
  "benchmark_name": "skillsbench",
  "repo_root": "../benchmarks/skillsbench",
  "registry_path": "../benchmarks/skillsbench/website/src/data/tasks-registry.json",
  "out_root": "../results/protocol_runs/skillsbench_oracle_real_suite",
  "execution": {
    "agent": "oracle",
    "model": null,
    "harbor_bin": "../scripts/harbor312",
    "jobs_dir": "../results/real_jobs_protocol",
    "path_type": "oracle",
    "agent_version": "harbor312-oracle-protocol-v0",
    "seed": 0,
    "task_preparation": {
      "mode": "copy",
      "skill_mode": "keep",
      "patches": {
        "dialogue-parser": [
          "dialogue_parser_apt_retry"
        ],
        "citation-check": [
          "citation_check_apt_retry"
        ]
      }
    },
    "retry_policy": {
      "max_attempts": 2,
      "retry_on_execution_statuses": [
        "failed"
      ],
      "retry_on_exception_types": [
        "EnvironmentStartTimeoutError",
        "EnvironmentBuildTimeoutError",
        "AgentSetupTimeoutError"
      ],
      "retry_on_message_substrings": [
        "e: failed to fetch",
        "unable to fetch some archives",
        "temporary failure resolving",
        "connection was forcibly closed",
        "timed out"
      ]
    },
    "extra_args": [
      "--artifact",
      "/logs/verifier",
      "--environment-build-timeout-multiplier",
      "4"
    ]
  },
  "runs": [
    {
      "run_name": "t0_replay",
      "phase": "T0",
      "benchmark_split": "replay",
      "task_ids": [
        "dialogue-parser"
      ]
    },
    {
      "run_name": "t0_heldout",
      "phase": "T0",
      "benchmark_split": "heldout",
      "task_ids": [
        "citation-check"
      ]
    },
    {
      "run_name": "t1_replay",
      "phase": "T1",
      "benchmark_split": "replay",
      "task_ids": [
        "dialogue-parser"
      ]
    },
    {
      "run_name": "t1_heldout",
      "phase": "T1",
      "benchmark_split": "heldout",
      "task_ids": [
        "citation-check"
      ]
    }
  ]
}
