{
  "schema_version": "0.1.0",
  "suite_name": "skillsbench-codex-external-prepared-host-auth-hard-candidate",
  "benchmark_name": "skillsbench",
  "repo_root": "../benchmarks/skillsbench",
  "registry_path": "../benchmarks/skillsbench/website/src/data/tasks-registry.json",
  "out_root": "../results/protocol_runs/skillsbench_codex_external_prepared_host_auth_hard_candidate_bundle",
  "execution": {
    "agent": "codex",
    "agent_import_path": "sip_bench.harbor_codex_host_agent:CodexLocalAuthAgent",
    "model": "gpt-5.4",
    "harbor_bin": "../scripts/harbor312",
    "jobs_dir": "../results/real_jobs_protocol_prepared_host_auth_hard_candidate_bundle",
    "path_type": "external",
    "agent_version": "harbor312-codex-host-auth-v0",
    "task_preparation": {
      "skip_hydration_if_local": true
    },
    "seed": 0,
    "retry_policy": {
      "max_attempts": 2,
      "retry_on_execution_statuses": [
        "failed"
      ],
      "retry_on_exception_types": [
        "EnvironmentStartTimeoutError",
        "EnvironmentBuildTimeoutError",
        "AgentSetupTimeoutError"
      ],
      "retry_on_message_substrings": [
        "e: failed to fetch",
        "unable to fetch some archives",
        "temporary failure resolving",
        "connection was forcibly closed",
        "timed out",
        "error listing credentials",
        "UtilAcceptVsock",
        "accept4 failed 110",
        "curl: (22)",
        "uvx: command not found"
      ]
    },
    "extra_args": [
      "--artifact",
      "/logs/verifier",
      "--environment-build-timeout-multiplier",
      "4",
      "--agent-setup-timeout-multiplier",
      "4"
    ]
  },
  "runs": [
    {
      "run_name": "t0_replay",
      "phase": "T0",
      "benchmark_split": "replay",
      "task_ids": [
        "enterprise-information-search"
      ],
      "task_preparation": {
        "mode": "copy",
        "skill_mode": "strip",
        "patches": {
          "enterprise-information-search": []
        }
      }
    },
    {
      "run_name": "t0_heldout",
      "phase": "T0",
      "benchmark_split": "heldout",
      "task_ids": [
        "financial-modeling-qa"
      ],
      "task_preparation": {
        "mode": "copy",
        "skill_mode": "strip",
        "patches": {
          "financial-modeling-qa": []
        }
      }
    },
    {
      "run_name": "t1_replay",
      "phase": "T1",
      "benchmark_split": "replay",
      "task_ids": [
        "enterprise-information-search"
      ],
      "task_preparation": {
        "mode": "copy",
        "skill_mode": "keep",
        "patches": {
          "enterprise-information-search": []
        }
      }
    },
    {
      "run_name": "t1_heldout",
      "phase": "T1",
      "benchmark_split": "heldout",
      "task_ids": [
        "financial-modeling-qa"
      ],
      "task_preparation": {
        "mode": "copy",
        "skill_mode": "keep",
        "patches": {
          "financial-modeling-qa": []
        }
      }
    }
  ]
}
