{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sip-bench.local/schemas/protocol_suite.schema.json",
  "title": "SIP-Bench Protocol Suite Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite_name",
    "benchmark_name",
    "repo_root",
    "out_root",
    "execution",
    "runs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "suite_name": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_name": {
      "type": "string",
      "enum": [
        "skillsbench",
        "tau-bench"
      ]
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "registry_path": {
      "type": "string",
      "minLength": 1
    },
    "out_root": {
      "type": "string",
      "minLength": 1
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "harbor_bin": {
          "type": "string",
          "minLength": 1
        },
        "jobs_dir": {
          "type": "string",
          "minLength": 1
        },
        "python_bin": {
          "type": "string",
          "minLength": 1
        },
        "env_file": {
          "type": "string",
          "minLength": 1
        },
        "env": {
          "type": "string",
          "enum": [
            "retail",
            "airline"
          ]
        },
        "task_split": {
          "type": "string",
          "enum": [
            "train",
            "dev",
            "test"
          ]
        },
        "model_provider": {
          "type": "string",
          "minLength": 1
        },
        "user_model": {
          "type": "string",
          "minLength": 1
        },
        "user_model_provider": {
          "type": "string",
          "minLength": 1
        },
        "agent_strategy": {
          "type": "string",
          "enum": [
            "tool-calling",
            "act",
            "react",
            "few-shot"
          ]
        },
        "user_strategy": {
          "type": "string",
          "enum": [
            "human",
            "llm",
            "react",
            "verify",
            "reflection"
          ]
        },
        "num_trials": {
          "type": "integer",
          "minimum": 1
        },
        "max_concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "log_dir": {
          "type": "string",
          "minLength": 1
        },
        "few_shot_displays_path": {
          "type": "string",
          "minLength": 1
        },
        "path_type": {
          "type": "string",
          "enum": [
            "frozen",
            "external",
            "parameter",
            "oracle"
          ]
        },
        "agent_version": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "integer"
        },
        "extra_args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "task_preparation": {
          "$ref": "#/$defs/taskPreparation"
        },
        "retry_policy": {
          "$ref": "#/$defs/retryPolicy"
        }
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_name",
          "phase",
          "benchmark_split",
          "task_ids"
        ],
        "properties": {
          "run_name": {
            "type": "string",
            "minLength": 1
          },
          "phase": {
            "type": "string",
            "enum": [
              "T0",
              "T1",
              "T2"
            ]
          },
          "benchmark_split": {
            "type": "string",
            "enum": [
              "replay",
              "adapt",
              "heldout",
              "drift"
            ]
          },
          "task_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "integer"
                }
              ]
            },
            "uniqueItems": true
          },
          "path_type": {
            "type": "string",
            "enum": [
              "frozen",
              "external",
              "parameter",
              "oracle"
            ]
          },
          "seed": {
            "type": "integer"
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "harbor_bin": {
            "type": "string",
            "minLength": 1
          },
          "job_name": {
            "type": "string",
            "minLength": 1
          },
          "jobs_dir": {
            "type": "string",
            "minLength": 1
          },
          "source_job_dir": {
            "type": "string",
            "minLength": 1
          },
          "source_result_file": {
            "type": "string",
            "minLength": 1
          },
          "agent_version": {
            "type": "string",
            "minLength": 1
          },
          "agent_name": {
            "type": "string",
            "minLength": 1
          },
          "model_name": {
            "type": "string",
            "minLength": 1
          },
          "extra_args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "python_bin": {
            "type": "string",
            "minLength": 1
          },
          "env_file": {
            "type": "string",
            "minLength": 1
          },
          "env": {
            "type": "string",
            "enum": [
              "retail",
              "airline"
            ]
          },
          "task_split": {
            "type": "string",
            "enum": [
              "train",
              "dev",
              "test"
            ]
          },
          "model_provider": {
            "type": "string",
            "minLength": 1
          },
          "user_model": {
            "type": "string",
            "minLength": 1
          },
          "user_model_provider": {
            "type": "string",
            "minLength": 1
          },
          "agent_strategy": {
            "type": "string",
            "enum": [
              "tool-calling",
              "act",
              "react",
              "few-shot"
            ]
          },
          "user_strategy": {
            "type": "string",
            "enum": [
              "human",
              "llm",
              "react",
              "verify",
              "reflection"
            ]
          },
          "num_trials": {
            "type": "integer",
            "minimum": 1
          },
          "max_concurrency": {
            "type": "integer",
            "minimum": 1
          },
          "log_dir": {
            "type": "string",
            "minLength": 1
          },
          "few_shot_displays_path": {
            "type": "string",
            "minLength": 1
          },
          "task_preparation": {
            "$ref": "#/$defs/taskPreparation"
          },
          "retry_policy": {
            "$ref": "#/$defs/retryPolicy"
          }
        }
      }
    }
  },
  "$defs": {
    "taskPreparation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "source",
            "copy"
          ]
        },
        "skill_mode": {
          "type": "string",
          "enum": [
            "keep",
            "strip"
          ]
        },
        "patches": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "offer_letter_generator_system_docx"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "require_all_records_failed": {
          "type": "boolean"
        },
        "retry_on_execution_statuses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "success",
              "failed",
              "missing_executable"
            ]
          },
          "uniqueItems": true
        },
        "retry_on_exception_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "retry_on_message_substrings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
