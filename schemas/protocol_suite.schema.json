{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sip-bench.local/schemas/protocol_suite.schema.json",
  "title": "SIP-Bench Protocol Suite Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite_name",
    "benchmark_name",
    "repo_root",
    "registry_path",
    "out_root",
    "execution",
    "runs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "suite_name": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_name": {
      "type": "string",
      "const": "skillsbench"
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "registry_path": {
      "type": "string",
      "minLength": 1
    },
    "out_root": {
      "type": "string",
      "minLength": 1
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent",
        "harbor_bin",
        "jobs_dir",
        "path_type",
        "agent_version"
      ],
      "properties": {
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "harbor_bin": {
          "type": "string",
          "minLength": 1
        },
        "jobs_dir": {
          "type": "string",
          "minLength": 1
        },
        "path_type": {
          "type": "string",
          "enum": [
            "frozen",
            "external",
            "parameter",
            "oracle"
          ]
        },
        "agent_version": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "integer"
        },
        "extra_args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_name",
          "phase",
          "benchmark_split",
          "task_ids"
        ],
        "properties": {
          "run_name": {
            "type": "string",
            "minLength": 1
          },
          "phase": {
            "type": "string",
            "enum": [
              "T0",
              "T1",
              "T2"
            ]
          },
          "benchmark_split": {
            "type": "string",
            "enum": [
              "replay",
              "adapt",
              "heldout",
              "drift"
            ]
          },
          "task_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "path_type": {
            "type": "string",
            "enum": [
              "frozen",
              "external",
              "parameter",
              "oracle"
            ]
          },
          "seed": {
            "type": "integer"
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "harbor_bin": {
            "type": "string",
            "minLength": 1
          },
          "job_name": {
            "type": "string",
            "minLength": 1
          },
          "jobs_dir": {
            "type": "string",
            "minLength": 1
          },
          "source_job_dir": {
            "type": "string",
            "minLength": 1
          },
          "agent_version": {
            "type": "string",
            "minLength": 1
          },
          "agent_name": {
            "type": "string",
            "minLength": 1
          },
          "model_name": {
            "type": "string",
            "minLength": 1
          },
          "extra_args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
