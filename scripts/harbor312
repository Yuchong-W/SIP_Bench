#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export UV_CACHE_DIR="${SCRIPT_DIR}/../.uv-cache"
export PYTHONUTF8=1
export PYTHONIOENCODING=utf-8
export NO_COLOR=1
export DOCKER_BUILDKIT=0
export COMPOSE_DOCKER_CLI_BUILD=0
export BUILDKIT_PROGRESS=plain
export PYTHONPATH="${SCRIPT_DIR}/../tools/harbor_codex_bridge:${SCRIPT_DIR}/../src${PYTHONPATH:+:$PYTHONPATH}"
export SIP_HARBOR_CODEX_AUTH_SOURCE="${HOME}/.codex/auth.json"

if command -v harbor >/dev/null 2>&1; then
  exec harbor "$@"
fi

exec uvx --python 3.12 harbor "$@"
